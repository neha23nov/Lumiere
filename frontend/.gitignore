# ─────────────────────────────────────────
# FRAMR — .gitignore
# Place this at the root of your project
# ─────────────────────────────────────────

# ─────────────────────────────────────────
# ENVIRONMENT FILES
# contains API keys, DB passwords, secrets
# NEVER commit these
# ─────────────────────────────────────────
.env
.env.local
.env.development
.env.production
.env.test
.env*.local
*.env

# ─────────────────────────────────────────
# NODE MODULES
# downloaded by npm install — never commit
# ─────────────────────────────────────────
node_modules/
*/node_modules/
**/node_modules/

# ─────────────────────────────────────────
# BUILD OUTPUTS
# ─────────────────────────────────────────
dist/
build/
out/
.vite/
vite.config.js.timestamp-*

# ─────────────────────────────────────────
# LOGS
# ─────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─────────────────────────────────────────
# OS FILES
# ─────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ─────────────────────────────────────────
# EDITORS
# ─────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo

# ─────────────────────────────────────────
# UPLOADS — stored on ImageKit
# ─────────────────────────────────────────
uploads/
public/uploads/
backend/uploads/

# ─────────────────────────────────────────
# TEST FILES
# ─────────────────────────────────────────
coverage/
test-*.js
*.test.js.snap

# ─────────────────────────────────────────
# MISC
# ─────────────────────────────────────────
*.pem
*.key
.cache/
.eslintcache
*.tsbuildinfo
.yarn/
.npm